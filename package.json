{
  "name": "@fohte/eslint-config",
  "description": "ESLint config for fohte",
  "version": "0.3.1",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "files": [
    "lib",
    "!lib/**/*.map",
    "!lib/**/*.test.*"
  ],
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/fohte/eslint-config.git"
  },
  "author": "fohte <fohte.hk@gmail.com>",
  "license": "MIT",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "engines": {
    "node": ">=20.19.0 || >=22.13.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "prebuild": "pnpm run clean",
    "build": "tsc && pnpm run copy-types",
    "copy-types": "mkdir -p lib/types && cp src/types/*.d.ts lib/types/",
    "watch": "tsc -w",
    "lint": "eslint src",
    "test": "vitest",
    "prepublishOnly": "pnpm run lint && pnpm run build",
    "postbuild": "pnpm run validate-build",
    "validate-build": "publint"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@eslint/eslintrc": "3.3.5",
    "@fohte/eslint-config": "0.3.1",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "24.12.0",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "concurrently": "9.2.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "rimraf": "6.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.0.0 || ^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
